{
  "name": "los-enfermos-tcg",
  "productName": "Los Enfermos - El TCG del Manicomio",
  "version": "1.0.0",
  "description": "Juego de cartas 1v1 estilo Hearthstone con el lore de Los Enfermos",
  "main": "electron/main.js",
  "author": "Los Enfermos",
  "license": "UNLICENSED",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win portable",
    "build:www": "node scripts/build-www.js",
    "apk": "node scripts/build-www.js && npx cap sync android && cd android && .\\gradlew.bat assembleDebug"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.1",
    "@capacitor/cli": "^8.4.1",
    "@capacitor/core": "^8.4.1",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.losenfermos.tcg",
    "files": [
      "index.html",
      "css/**",
      "js/**",
      "assets/**",
      "electron/**",
      "package.json",
      "node_modules/ws/**"
    ],
    "win": {
      "target": "portable"
    }
  }
}
